{
  "scanner": {
    "min_volume": 5000,
    "max_days_left": 7,
    "min_prob": 0.70,
    "max_prob": 0.95,
    "side": "both",
    "api_batch_size": 500,
    "clob_timeout": 5,
    "clob_workers": 10
  },
  "analyzer": {
    "sma_windows": [3, 7, 14],
    "volatility_window": 7,
    "momentum_window": 3,
    "zscore_window": 14
  },
  "sentiment": {
    "rss_feeds": [
      "https://news.google.com/rss/search?q=politics&hl=en-US&gl=US&ceid=US:en",
      "https://news.google.com/rss/search?q=geopolitics+policy&hl=en-US&gl=US&ceid=US:en",
      "https://news.google.com/rss/search?q=economy+regulation&hl=en-US&gl=US&ceid=US:en"
    ],
    "weight": 0.20
  },
  "scoring": {
    "weights": {
      "statistical": 0.40,
      "sentiment": 0.20,
      "arbitrage": 0.25,
      "volume": 0.15
    }
  },
  "self_improve": {
    "accuracy_target": 0.65,
    "learning_rate": 0.05,
    "min_predictions_for_adjust": 10,
    "lookback_days": 30
  },
  "email": {
    "to": "fturan.zero@gmail.com",
    "from_email": "polymarket-scanner@financedeep.dive",
    "from_name": "Polymarket Scanner",
    "subject_prefix": "[Polymarket]"
  },
