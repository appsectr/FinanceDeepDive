    "\\bwin on \\d{4}-\\d{2}-\\d{2}\\b", "\\bend in a draw\\b",
    "\\bvs\\.?\\b", "\\bGame \\d+ Winner\\b", "\\bMap \\d+ Winner\\b",
    "\\b[OoUu]/[OoUu]\\b", "\\bO/U\\b", "\\bHandicap\\b", "\\bSpread\\b",
    "\\bscore a (TD|touchdown|goal)\\b", "\\bmoneyline\\b",
    "\\b(Serie A|La Liga|Ligue 1|Bundesliga|Premier League|Eredivisie|MLS|EFL|EFL Cup)\\b",
    "\\b(NBA|NHL|NFL|MLB|MLS|NCAA|UFC|ATP|WTA|F1|Formula 1|Grand Prix)\\b",
    "\\b(Flag Football|Golf|PGA|Valspar|Championship|World Cup|Super Bowl|Stanley Cup|Champions League)\\b",
    "\\bCounter-Strike\\b", "\\bCS2\\b", "\\bDota 2\\b", "\\bValorant\\b",
    "\\bLeague of Legends\\b", "\\bLoL\\b", "\\bOverwatch\\b", "\\bRocket League\\b",
    "\\b(BO[1-5])\\b", "\\bESL\\b", "\\bBLAST\\b", "\\bVCL\\b", "\\bFirst Stand\\b",
    "\\b(Esports|esports|eSports|Gaming)\\b", "\\bGames Total\\b",
    "\\bprice of (Bitcoin|Ethereum|XRP|SOL|BNB|Dogecoin|Solana|Cardano|Polkadot)\\b",
    "\\b(Bitcoin|Ethereum|BTC|ETH|XRP|SOL|BNB|DOGE) (above|below|between|dip|hit|reach|drop)\\b",
    "\\bUp or Down\\b", "\\bcrypto.*daily\\b",
    "\\b(highest|lowest|average) temperature\\b", "\\bweather\\b",
    "\\b[°]\\s?[CF]\\b", "\\btemperature in\\b",
    "\\btweet", "\\btweets\\b", "\\btweet count\\b",
